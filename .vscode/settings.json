
{
  "nix.serverPath": "nixd",
  "nix.enableLanguageServer": true,
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": [ "nixfmt" ], // or nixfmt or nixpkgs-fmt
      },
       "options": {
          "nixos": {
         "expr": "(builtins.getFlake \"~/macwillos\").nixosConfigurations.nixtop.options"
          },
         "home_manager": {
          "expr": "(builtins.getFlake \"~/macwillos\").homeConfigurations.nixtop.options"
          },
       },
    }
  }
}
